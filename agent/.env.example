# =============================================================================
# KARMA PROTOCOL Agent -- .env.example
# Copy to .env and fill in real values.  NEVER commit .env.
# =============================================================================

# --- Chain -------------------------------------------------------------------

# Primary RPC endpoint (required)
# Alchemy: https://base-sepolia.g.alchemy.com/v2/<API_KEY>
# Infura:  https://base-sepolia.infura.io/v3/<PROJECT_ID>
# Anvil:   http://127.0.0.1:8545
RPC_URL_PRIMARY=

# Optional comma-separated fallback RPCs (used if primary fails)
RPC_URL_FALLBACK=

# Chain ID -- must match the RPC endpoint
#   84532  = Base Sepolia (default)
#   8453   = Base Mainnet
#   42161  = Arbitrum One
#   421614 = Arbitrum Sepolia
#   1      = Ethereum Mainnet
CHAIN_ID=84532

# --- Contracts ---------------------------------------------------------------

# From contracts/deployments/<chainId>.json after running Deploy.s.sol
KARMA_HOOK_ADDRESS=
KARMA_REGISTRY_ADDRESS=

# --- Agent wallet ------------------------------------------------------------

# Private key of the wallet authorised as `agent` in KarmaRegistry.
# Generate a fresh key: cast wallet new
# NEVER use a wallet that holds real funds on mainnet.
AGENT_PRIVATE_KEY=

# --- Redis -------------------------------------------------------------------

# Local Docker:  redis://localhost:6379   (run: docker compose up -d)
# Railway:       injected automatically — do not set this manually on Railway
# Upstash (TLS): rediss://default:<token>@<host>:<port>
REDIS_URL=redis://localhost:6379

# --- Polling -----------------------------------------------------------------

# How often to run the main loop (ms). Default: 60000 (1 min)
POLL_INTERVAL_MS=60000

# Block to start scanning from on first run.
# Set to the block your KarmaHook was deployed at to skip old history.
START_BLOCK=0

# Max blocks per getLogs call. Keep <= 2000 for Alchemy/Infura free tier.
BLOCK_BATCH_SIZE=2000

# --- Scoring -----------------------------------------------------------------

# Rolling window for scoring in days. Events older than this are ignored.
SCORING_WINDOW_DAYS=90

# --- Batching ----------------------------------------------------------------

# Flush the pending batch when this many entries are queued.
BATCH_TARGET_SIZE=200

# Flush the pending batch if the oldest entry is this many seconds old.
BATCH_MAX_AGE_SEC=30

# Minimum score delta to trigger an on-chain write.
# Prevents burning gas on minor fluctuations.  Set to 0 to write every change.
MIN_SCORE_DELTA=2

# --- HTTP health server ------------------------------------------------------

# Railway will health-check this port.
PORT=3001

# --- Logging -----------------------------------------------------------------

# "json" = structured JSON (production / Railway)
# "pretty" = human-readable (local dev with pino-pretty)
LOG_MODE=json
LOG_LEVEL=info

# --- Rate limiting -----------------------------------------------------------

# Max RPC requests per second (across getLogs, getBlock, etc.)
# Alchemy free: 330/s  |  Infura free: 100/s  |  Anvil: unlimited
RPC_RPS=50
